#!/usr/bin/env bash
# cua — Claw Use CLI
# Control Android phones via Claw Use HTTP API
# Usage: cua <command> [args...]

set -euo pipefail

# Config: env vars or ~/.config/claw-use/config
CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/claw-use"
CONFIG_FILE="$CONFIG_DIR/config"
DEVICES_FILE="$CONFIG_DIR/devices"

# Load config (default device)
if [ -f "$CONFIG_FILE" ]; then
  source "$CONFIG_FILE"
fi

CU_HOST="${CU_HOST:-}"
CU_TOKEN="${CU_TOKEN:-}"
CU_TIMEOUT="${CU_TIMEOUT:-10}"
CU_DEVICE="${CU_DEVICE:-}"

# If a device alias is set, load from devices file
_load_device() {
  local name="$1"
  if [ -f "$DEVICES_FILE" ]; then
    local line=$(grep "^${name}|" "$DEVICES_FILE" 2>/dev/null | head -1)
    if [ -n "$line" ]; then
      CU_HOST=$(echo "$line" | cut -d'|' -f2)
      CU_TOKEN=$(echo "$line" | cut -d'|' -f3)
      return 0
    fi
  fi
  return 1
}

# Resolve device: env CU_DEVICE > --device flag > default config
_resolve_device() {
  if [ -n "$CU_DEVICE" ]; then
    _load_device "$CU_DEVICE" || _err "Unknown device: $CU_DEVICE. Run 'cua devices' to list."
  fi
}

# Colors
RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[0;33m'; CYAN='\033[0;36m'; NC='\033[0m'

_err() { echo -e "${RED}error:${NC} $*" >&2; exit 1; }
_ok() { echo -e "${GREEN}$*${NC}"; }

_require_config() {
  _resolve_device
  [ -n "$CU_HOST" ] || _err "CU_HOST not set. Run: cua add <name> <ip> <token>"
  [ -n "$CU_TOKEN" ] || _err "CU_TOKEN not set. Run: cua add <name> <ip> <token>"
}

_api() {
  local method="$1" path="$2"; shift 2
  local url="http://${CU_HOST}:7333${path}"
  local auth_args=()
  if [ "$path" != "/ping" ]; then
    auth_args=(-H "X-Bridge-Token:${CU_TOKEN}")
  fi
  curl -s --connect-timeout 5 -m "$CU_TIMEOUT" -X "$method" "${auth_args[@]}" "$@" "$url" 2>&1
}

_api_json() {
  _api "$@" -H "Content-Type: application/json"
}

_jq_or_raw() {
  if [ -t 1 ] && command -v jq &>/dev/null; then
    jq -C '.' 2>/dev/null || cat
  elif command -v jq &>/dev/null; then
    jq '.' 2>/dev/null || cat
  else
    cat
  fi
}

cmd_setup() {
  # Legacy: cua setup <ip> <token> → saves as default
  local host="${1:-}" token="${2:-}"
  [ -n "$host" ] && [ -n "$token" ] || _err "Usage: cua setup <ip> <token>  (or use: cua add <name> <ip> <token>)"
  mkdir -p "$CONFIG_DIR"
  cat > "$CONFIG_FILE" <<EOF
CU_HOST="$host"
CU_TOKEN="$token"
EOF
  chmod 600 "$CONFIG_FILE"
  CU_HOST="$host" CU_TOKEN="$token"
  local result=$(_api GET /ping)
  if echo "$result" | grep -q '"ok"'; then
    local version=$(echo "$result" | grep -o '"version":"[^"]*"' | cut -d'"' -f4)
    _ok "Connected to Claw Use $version at $host (default device)"
  else
    echo -e "${YELLOW}warning:${NC} saved but ping failed: $result"
  fi
}

cmd_add() {
  local name="${1:-}" host="${2:-}" token="${3:-}"
  [ -n "$name" ] && [ -n "$host" ] && [ -n "$token" ] || _err "Usage: cua add <name> <ip> <token>"
  mkdir -p "$CONFIG_DIR"
  touch "$DEVICES_FILE"
  chmod 600 "$DEVICES_FILE"
  # Remove existing entry with same name
  sed -i "/^${name}|/d" "$DEVICES_FILE"
  echo "${name}|${host}|${token}" >> "$DEVICES_FILE"
  
  # Test connection
  CU_HOST="$host" CU_TOKEN="$token"
  local result=$(_api GET /ping)
  if echo "$result" | grep -q '"ok"'; then
    local version=$(echo "$result" | grep -o '"version":"[^"]*"' | cut -d'"' -f4)
    _ok "Added '$name' → $host (Claw Use $version)"
  else
    _ok "Added '$name' → $host"
    echo -e "${YELLOW}warning:${NC} ping failed: $result"
  fi
  
  # Set as default if it's the first/only device
  local count=$(wc -l < "$DEVICES_FILE")
  if [ "$count" -eq 1 ] || [ ! -f "$CONFIG_FILE" ]; then
    cmd_use "$name"
  fi
}

cmd_devices() {
  if [ ! -f "$DEVICES_FILE" ] || [ ! -s "$DEVICES_FILE" ]; then
    echo "No devices configured. Run: cua add <name> <ip> <token>"
    return
  fi
  
  # Get current default
  local current_host="${CU_HOST:-}"
  
  echo -e "${CYAN}DEVICES${NC}"
  while IFS='|' read -r name host token; do
    local marker="  "
    if [ "$host" = "$current_host" ]; then marker="${GREEN}▸ ${NC}"; fi
    
    # Quick ping (1s timeout)
    local status="${RED}offline${NC}"
    local ping_result=$(curl -s --connect-timeout 1 -m 2 "http://${host}:7333/ping" 2>&1)
    if echo "$ping_result" | grep -q '"ok"'; then
      local ver=$(echo "$ping_result" | grep -o '"version":"[^"]*"' | cut -d'"' -f4)
      status="${GREEN}online${NC} v${ver}"
    fi
    
    echo -e "${marker}${name}\t${host}\t${status}"
  done < "$DEVICES_FILE"
}

cmd_use() {
  local name="${1:-}"
  [ -n "$name" ] || _err "Usage: cua use <device-name>"
  
  if ! _load_device "$name"; then
    _err "Unknown device: $name. Run 'cua devices' to list."
  fi
  
  mkdir -p "$CONFIG_DIR"
  cat > "$CONFIG_FILE" <<EOF
CU_HOST="$CU_HOST"
CU_TOKEN="$CU_TOKEN"
EOF
  chmod 600 "$CONFIG_FILE"
  _ok "Default device: $name ($CU_HOST)"
}

cmd_rm() {
  local name="${1:-}"
  [ -n "$name" ] || _err "Usage: cua rm <device-name>"
  if [ -f "$DEVICES_FILE" ]; then
    sed -i "/^${name}|/d" "$DEVICES_FILE"
    _ok "Removed '$name'"
  else
    _err "No devices configured"
  fi
}

cmd_discover() {
  local target_subnet="${1:-}"
  echo -e "${CYAN}Scanning for Claw Use devices...${NC}"
  
  local subnets=()
  if [ -n "$target_subnet" ]; then
    subnets+=("$target_subnet")
  else
    # Default: scan 192.168.x subnets (where phones live)
    # Check which 192.168.x.x subnets we can reach
    while IFS= read -r ip; do
      local subnet=$(echo "$ip" | sed 's/\.[0-9]*$//')
      local dup=0
      for s in "${subnets[@]:-}"; do [ "$s" = "$subnet" ] && dup=1; done
      [ "$dup" -eq 0 ] && subnets+=("$subnet")
    done < <(ip -4 addr show | grep -oP 'inet \K192\.168\.[0-9.]+')
    
    # If no 192.168.x interface, scan common ones
    if [ ${#subnets[@]} -eq 0 ]; then
      subnets=("192.168.0" "192.168.1")
    fi
  fi
  
  for subnet in "${subnets[@]}"; do
    echo "Scanning ${subnet}.0/24 ..."
    for i in $(seq 1 254); do
      (
        local ip="${subnet}.${i}"
        local result=$(curl -s --connect-timeout 1 -m 2 "http://${ip}:7333/ping" 2>/dev/null)
        if echo "$result" | grep -q '"claw-use-android"' 2>/dev/null; then
          local ver=$(echo "$result" | grep -o '"version":"[^"]*"' | cut -d'"' -f4)
          echo -e "  ${GREEN}found${NC}  ${ip}:7333  v${ver}"
        fi
      ) &
    done
    wait
  done
  
  echo ""
  echo "To add: cua add <name> <ip> <token>"
}

cmd_ping() {
  _api GET /ping | _jq_or_raw
}

cmd_info() {
  _require_config
  _api GET /info | _jq_or_raw
}

cmd_status() {
  _require_config
  _api GET /status | _jq_or_raw
}

cmd_screen() {
  _require_config
  local params=()
  local prev=""
  for arg in "$@"; do
    case "$arg" in
      -c|--compact) params+=("compact=true") ;;
      -t|--timeout) ;;
      *)
        if [[ "$prev" == "-t" || "$prev" == "--timeout" ]]; then
          params+=("timeout=$arg")
        fi
        ;;
    esac
    prev="$arg"
  done
  local qs=""
  if [ ${#params[@]} -gt 0 ]; then
    qs="?$(IFS='&'; echo "${params[*]}")"
  fi
  _api GET "/screen${qs}" | _jq_or_raw
}

cmd_screenshot() {
  _require_config
  local quality="${1:-50}" maxWidth="${2:-720}" output="${3:-}"
  local result=$(_api GET "/screenshot?quality=$quality&maxWidth=$maxWidth")
  
  if echo "$result" | grep -q '"error"'; then
    echo "$result" | _jq_or_raw
    return 1
  fi
  
  local size=$(echo "$result" | grep -o '"sizeBytes":[0-9]*' | cut -d: -f2)
  
  if [ -n "$output" ]; then
    echo "$result" | python3 -c "
import sys,json,base64
d=json.load(sys.stdin)
with open('$output','wb') as f: f.write(base64.b64decode(d['screenshot']))
" && _ok "Saved ${size}B → $output"
  else
    # Save to temp
    local tmp="/tmp/cu-screenshot-$(date +%s).jpg"
    echo "$result" | python3 -c "
import sys,json,base64
d=json.load(sys.stdin)
with open('$tmp','wb') as f: f.write(base64.b64decode(d['screenshot']))
"
    _ok "${size}B → $tmp"
    echo "$tmp"
  fi
}

cmd_tap() {
  _require_config
  local x="${1:-}" y="${2:-}"
  [ -n "$x" ] && [ -n "$y" ] || _err "Usage: cu tap <x> <y>"
  _api_json POST /tap -d "{\"x\":$x,\"y\":$y}" | _jq_or_raw
}

cmd_click() {
  _require_config
  local text="$*"
  [ -n "$text" ] || _err "Usage: cu click <text>"
  _api_json POST /click -d "{\"text\":\"$text\"}" | _jq_or_raw
}

cmd_longpress() {
  _require_config
  local x="${1:-}" y="${2:-}"
  [ -n "$x" ] && [ -n "$y" ] || _err "Usage: cu longpress <x> <y>"
  _api_json POST /longpress -d "{\"x\":$x,\"y\":$y}" | _jq_or_raw
}

cmd_swipe() {
  _require_config
  local dir="${1:-up}"
  _api_json POST /swipe -d "{\"direction\":\"$dir\"}" | _jq_or_raw
}

cmd_scroll() {
  _require_config
  local dir="${1:-down}"
  _api_json POST /scroll -d "{\"direction\":\"$dir\"}" | _jq_or_raw
}

cmd_type() {
  _require_config
  local text="$*"
  [ -n "$text" ] || _err "Usage: cu type <text>"
  # JSON-escape the text
  local escaped=$(python3 -c "import json; print(json.dumps('$text')[1:-1])" 2>/dev/null || echo "$text")
  _api_json POST /type -d "{\"text\":\"$escaped\"}" | _jq_or_raw
}

cmd_back() { _require_config; _api_json POST /global -d '{"action":"back"}' | _jq_or_raw; }
cmd_home() { _require_config; _api_json POST /global -d '{"action":"home"}' | _jq_or_raw; }
cmd_recents() { _require_config; _api_json POST /global -d '{"action":"recents"}' | _jq_or_raw; }

cmd_launch() {
  _require_config
  local pkg="${1:-}"
  if [ -z "$pkg" ]; then
    # List apps
    _api GET /launch | _jq_or_raw
  else
    _api_json POST /launch -d "{\"package\":\"$pkg\"}" | _jq_or_raw
  fi
}

cmd_tts() {
  _require_config
  local text="$*"
  [ -n "$text" ] || _err "Usage: cu tts <text>"
  CU_TIMEOUT=35 _api_json POST /tts -d "{\"text\":\"$text\"}" | _jq_or_raw
}

cmd_intent() {
  _require_config
  # Pass raw JSON body
  local body="${1:-}"
  [ -n "$body" ] || _err "Usage: cu intent '{\"action\":\"...\",\"uri\":\"...\"}'"
  _api_json POST /intent -d "$body" | _jq_or_raw
}

cmd_call() {
  _require_config
  local number="${1:-}"
  [ -n "$number" ] || _err "Usage: cu call <phone-number>"
  _api_json POST /intent -d "{\"action\":\"android.intent.action.CALL\",\"uri\":\"tel:$number\"}" | _jq_or_raw
}

cmd_open() {
  _require_config
  local url="${1:-}"
  [ -n "$url" ] || _err "Usage: cu open <url>"
  _api_json POST /intent -d "{\"action\":\"android.intent.action.VIEW\",\"uri\":\"$url\"}" | _jq_or_raw
}

cmd_notifications() {
  _require_config
  _api GET /notifications | _jq_or_raw
}

cmd_wake() { _require_config; _api_json POST /screen/wake | _jq_or_raw; }
cmd_lock() { _require_config; _api_json POST /screen/lock | _jq_or_raw; }
cmd_unlock() { _require_config; _api_json POST /screen/unlock | _jq_or_raw; }

cmd_config() {
  _require_config
  local subcmd="${1:-get}"; shift 2>/dev/null || true
  case "$subcmd" in
    get) _api GET /config | _jq_or_raw ;;
    set) _api_json POST /config -d "$1" | _jq_or_raw ;;
    pin) _api_json POST /config -d "{\"pin\":\"$1\"}" | _jq_or_raw ;;
    *) _err "Usage: cua config get|set|pin" ;;
  esac
}

cmd_help() {
  cat <<'EOF'
cua — Claw Use Android CLI

DEVICE MANAGEMENT
  cua add <name> <ip> <token>  Add a device with alias
  cua devices                  List all devices (with online status)
  cua discover                 Scan local network for devices
  cua use <name>               Set default device
  cua rm <name>                Remove a device
  cua setup <ip> <token>       Quick setup (legacy, no alias)

GLOBAL FLAGS
  -d, --device <name>         Target a specific device for this command
                              e.g. cua -d pixel screenshot

PERCEPTION
  cu ping                   Health check
  cu info                   Device info
  cu status                 Full health dashboard
  cu screen [-c] [-t ms]    Read UI tree (-c = compact)
  cua screenshot [q] [w] [f] Screenshot (quality, maxWidth, output file)
  cu notifications          List notifications

ACTION
  cu tap <x> <y>            Tap coordinates
  cu click <text>           Tap element by text
  cu longpress <x> <y>      Long press
  cu swipe <up|down|l|r>    Swipe
  cu scroll <up|down|l|r>   Scroll
  cu type <text>            Type text
  cu back                   Press back
  cu home                   Press home
  cu recents                Recent apps
  cu launch [package]       List apps / launch app
  cu open <url>             Open URL in browser
  cu call <number>          Make a phone call
  cu intent <json>          Fire raw Android Intent

AUDIO
  cu tts <text>             Speak through phone speaker

DEVICE
  cu wake                   Wake screen
  cu lock                   Lock device
  cu unlock                 Unlock (requires PIN configured)
  cua config get|set|pin     Read/write device config

ENV VARS
  CU_HOST      Phone IP/hostname (overrides device config)
  CU_TOKEN     Auth token (overrides device config)
  CU_DEVICE    Device alias (same as -d flag)
  CU_TIMEOUT   Request timeout in seconds (default: 10)

EXAMPLES
  cua add redmi 192.168.0.105 abc123     # add device
  cua add pixel 100.80.1.5 def456        # add another
  cua devices                             # list all
  cua -d pixel screenshot                 # screenshot from pixel
  cua use redmi                           # switch default
  cua say "hello"                         # speak on default device
EOF
}

# Parse global flags
while [[ "${1:-}" == -* ]]; do
  case "$1" in
    -d|--device) CU_DEVICE="$2"; shift 2 ;;
    *) break ;;
  esac
done

# Main dispatch
cmd="${1:-help}"; shift 2>/dev/null || true
case "$cmd" in
  setup) cmd_setup "$@" ;;
  add) cmd_add "$@" ;;
  devices|ls) cmd_devices ;;
  use) cmd_use "$@" ;;
  rm|remove) cmd_rm "$@" ;;
  discover|scan) cmd_discover ;;
  ping) cmd_ping ;;
  info) cmd_info ;;
  status) cmd_status ;;
  screen) cmd_screen "$@" ;;
  screenshot|ss) cmd_screenshot "$@" ;;
  tap) cmd_tap "$@" ;;
  click) cmd_click "$@" ;;
  longpress|lp) cmd_longpress "$@" ;;
  swipe) cmd_swipe "$@" ;;
  scroll) cmd_scroll "$@" ;;
  type) cmd_type "$@" ;;
  back) cmd_back ;;
  home) cmd_home ;;
  recents) cmd_recents ;;
  launch) cmd_launch "$@" ;;
  tts|say) cmd_tts "$@" ;;
  intent) cmd_intent "$@" ;;
  call) cmd_call "$@" ;;
  open) cmd_open "$@" ;;
  notifications|notif) cmd_notifications ;;
  wake) cmd_wake ;;
  lock) cmd_lock ;;
  unlock) cmd_unlock ;;
  config) cmd_config "$@" ;;
  help|--help|-h) cmd_help ;;
  *) _err "Unknown command: $cmd. Run 'cua help' for usage." ;;
esac
