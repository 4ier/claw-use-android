<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FF1A1A2E"
    android:padding="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Claw Use Android"
            android:textSize="24sp"
            android:textColor="#FFFFFFFF"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="AI Device Bridge"
            android:textSize="14sp"
            android:textColor="#80FFFFFF"
            android:layout_marginBottom="24dp" />

        <!-- Services -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FF16213E"
            android:padding="16dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:id="@+id/tv_accessibility"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="○ Accessibility Service: OFF"
                android:textSize="16sp"
                android:textColor="#FFF44336" />

            <Button
                android:id="@+id/btn_accessibility"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Enable Accessibility Service"
                android:layout_marginTop="8dp" />

            <TextView
                android:id="@+id/tv_notification"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="○ Notification Listener: OFF"
                android:textSize="16sp"
                android:textColor="#FFF44336"
                android:layout_marginTop="16dp" />

            <Button
                android:id="@+id/btn_notification"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Enable Notification Listener"
                android:layout_marginTop="8dp" />

        </LinearLayout>

        <!-- Connection -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FF16213E"
            android:padding="16dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Connection"
                android:textSize="18sp"
                android:textColor="#FFFFFFFF"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Bridge URL"
                android:textSize="12sp"
                android:textColor="#80FFFFFF" />

            <TextView
                android:id="@+id/tv_url"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="http://...:7333"
                android:textSize="16sp"
                android:textColor="#FF64FFDA"
                android:fontFamily="monospace"
                android:textIsSelectable="true" />

            <Button
                android:id="@+id/btn_copy_url"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Copy URL"
                android:layout_marginTop="4dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Auth Token"
                android:textSize="12sp"
                android:textColor="#80FFFFFF"
                android:layout_marginTop="12dp" />

            <TextView
                android:id="@+id/tv_token"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="..."
                android:textSize="14sp"
                android:textColor="#FFFFAB40"
                android:fontFamily="monospace"
                android:textIsSelectable="true" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="4dp">

                <Button
                    android:id="@+id/btn_copy_token"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Copy Token" />

                <Button
                    android:id="@+id/btn_reset_token"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Reset Token"
                    android:layout_marginStart="8dp" />

            </LinearLayout>

            <!-- QR Code -->
            <ImageView
                android:id="@+id/iv_qr"
                android:layout_width="200dp"
                android:layout_height="200dp"
                android:layout_gravity="center"
                android:layout_marginTop="16dp"
                android:contentDescription="QR Code" />

        </LinearLayout>

        <!-- Permissions -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FF16213E"
            android:padding="16dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Permissions"
                android:textSize="18sp"
                android:textColor="#FFFFFFFF"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tv_permissions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:textColor="#CCFFFFFF"
                android:lineSpacingExtra="4dp" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>
